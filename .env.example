# --- WhatsApp (Meta Cloud API) ---
# WHATSAPP_ENABLED=true
# WHATSAPP_PHONE_NUMBER_ID=1236770116181669
# WHATSAPP_ACCESS_TOKEN=              # Token PERMANENTE (ver abajo)
# WHATSAPP_API_VERSION=v25.0
# WHATSAPP_VERIFY_TOKEN=adoratio-verify
# WHATSAPP_COUNTRY_CODE=502
# WHATSAPP_TEST_TO=50242015748
# WHATSAPP_TEST_TEMPLATE=hello_world
#
# Token permanente (no expira):
#   business.facebook.com → Configuración → Usuarios del sistema
#   → Crear usuario → Asignar app + cuenta WhatsApp
#   → Generar token (whatsapp_business_messaging, whatsapp_business_management)
#   → Expiración: Nunca
#
# Actualizar en local + producción:
#   chmod +x scripts/update-whatsapp-token.sh
#   ./scripts/update-whatsapp-token.sh EAAxxxx...
#
# Webhook producción: https://adorahora.com/api/whatsapp/webhook
#
# ── Plantillas Meta (OBLIGATORIAS para recordatorios 24h/3h) ──
# Crear en business.facebook.com → WhatsApp Manager → Plantillas
# Textos exactos: config/whatsapp-templates.example.json
# WHATSAPP_BUSINESS_ACCOUNT_ID=1886920702000626
# WHATSAPP_TEMPLATE_LANGUAGE=es_MX
# WHATSAPP_APP_SECRET=                  # firma webhook X-Hub-Signature-256
# WHATSAPP_TEMPLATE_REMINDER_24H=adoratio_reminder_24h
# WHATSAPP_TEMPLATE_REMINDER_3H=adoratio_reminder_3h
# WHATSAPP_TEMPLATE_CAPTAIN_EMERGENCY=adoratio_captain_emergency
# WHATSAPP_TEMPLATE_BOOKING_CONFIRMED=adoratio_booking_confirmed
# WHATSAPP_REMINDER_INTERVAL_MS=300000
#
# Verificar plantillas en Meta: node scripts/list-whatsapp-templates.js
