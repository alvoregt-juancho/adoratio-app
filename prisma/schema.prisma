// Adoratio - esquema de datos.
// Provider SQLite para desarrollo sin configuracion.
// Para produccion (Postgres): cambia provider a "postgresql" y DATABASE_URL.
// Nota: se usan campos String para role/status/frequency en lugar de enum, ya que
// SQLite no soporta enums en Prisma. Valores permitidos documentados abajo.
// CommitmentFrequency: "ONCE" | "DAILY" | "WEEKLY" | "BIWEEKLY" | "MONTHLY" (ver src/constants/commitment.js)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// role: "superadmin" | "admin" | "lector" | "feligres" (legacy; prefer adminRoleId)
model User {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  passwordHash     String?   @map("password_hash")
  role             String    @default("feligres")
  adminRoleId      Int?      @map("admin_role_id")
  emailVerified    Boolean   @default(false) @map("email_verified")
  verificationCode String?   @map("verification_code")
  phoneNumber      String?   @unique @map("phone_number")
  createdAt        DateTime  @default(now()) @map("created_at")

  adminRole     AdminRole?  @relation(fields: [adminRoleId], references: [id])
  reservations  Reservation[]
  generatedQrs  PhysicalQR[]
  audits        AuditLog[]  @relation("AuditActor")
  targetedAudits AuditLog[] @relation("AuditTarget")
  createdRoles  AdminRole[] @relation("RoleCreator")
  captainRanges            CaptainRange[]
  captainRangesCreated     CaptainRange[]        @relation("CaptainRangeCreator")
  captainRangesUpdated     CaptainRange[]        @relation("CaptainRangeUpdater")
  captainNotifications     CaptainNotification[] @relation("CaptainNotifications")
  substitutionReviews      SubstitutionRequest[] @relation("SubstitutionReviews")
  attendanceLogs           AttendanceLog[]

  @@map("users")
}

// Perfil RBAC personalizable — privileges es un bitmask Int (ver src/constants/permissions.js)
model AdminRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  privileges  Int      @default(0)
  isSystem    Boolean  @default(false) @map("is_system")
  createdById Int?     @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users     User[]
  createdBy User? @relation("RoleCreator", fields: [createdById], references: [id])

  @@map("admin_roles")
}

model Slot {
  id         Int      @id @default(autoincrement())
  startTime  String   @map("start_time") // "HH:MM"
  endTime    String   @map("end_time")   // "HH:MM"
  capacity   Int      @default(4)
  label      String?
  weekDays   String?  @map("week_days") // "1,3" (Lun=1 … Dom=7); null = todos
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  reservations Reservation[]

  @@map("slots")
}

// frequency (CommitmentFrequency): "ONCE" | "DAILY" | "WEEKLY" | "BIWEEKLY" | "MONTHLY"
// status: "confirmed" | "completed" | "cancelled" | "no_show"
model Reservation {
  id               Int       @id @default(autoincrement())
  slotId           Int       @map("slot_id")
  userId           Int?      @map("user_id")
  userPhone        String    @map("user_phone")
  userFirstName    String    @default("") @map("user_first_name")
  userLastName     String    @default("") @map("user_last_name")
  userName         String    @map("user_name") // nombre completo (denormalizado)
  date             String    // "YYYY-MM-DD" del turno
  frequency        String    @default("WEEKLY")
  weekDays         String?   @map("week_days") // DAILY: "1,2,3" (Lun=1 … Dom=7)
  biweeklyWeeks    String?   @map("biweekly_weeks") // BIWEEKLY: "1,3" | "2,4"
  durationMinutes  Int       @default(60) @map("duration_minutes")
  startTimeOffset  Int       @default(0) @map("start_time_offset") // 0 o 30 minutos
  status           String    @default("confirmed")
  checkedInAt      DateTime? @map("checked_in_at")
  checkedInViaQrId Int?      @map("checked_in_via_qr_id")
  cancelledAt      DateTime? @map("cancelled_at")
  commitmentEndDate String?  @map("commitment_end_date") // YYYY-MM-DD último día inclusive
  createdAt        DateTime  @default(now()) @map("created_at")

  slot           Slot        @relation(fields: [slotId], references: [id])
  user           User?       @relation(fields: [userId], references: [id])
  checkedInViaQR PhysicalQR? @relation(fields: [checkedInViaQrId], references: [id])
  scanLogs              ScanLog[]
  audits                AuditLog[]
  prayerIntentions        PrayerIntention[]
  assignedPrayerIntention PrayerIntention?      @relation("AssignedPrayer")
  substitutionRequests    SubstitutionRequest[]

  @@map("reservations")
}

// visibility: siempre "wall" (todas las intenciones van al muro)
// displayName: con valor = personal (nombre visible); null = anónima
model PrayerIntention {
  id            Int       @id @default(autoincrement())
  text          String
  displayName   String?   @map("display_name")
  userPhone     String?   @map("user_phone")
  visibility    String    @default("wall")
  status        String    @default("active")
  reservationId           Int?      @map("reservation_id")
  assignedToReservationId Int?      @unique @map("assigned_to_reservation_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at")
  statusUpdatedAt         DateTime  @default(now()) @map("status_updated_at")
  prayedAt                DateTime? @map("prayed_at")
  deletedAt               DateTime? @map("deleted_at")

  reservation           Reservation? @relation(fields: [reservationId], references: [id])
  assignedToReservation Reservation? @relation("AssignedPrayer", fields: [assignedToReservationId], references: [id])

  @@index([visibility, status])
  @@index([status, statusUpdatedAt])
  @@map("prayer_intentions")
}

model PhysicalQR {
  id          Int       @id @default(autoincrement())
  qrCode      String    @unique @map("qr_code")
  displayName String    @map("display_name")
  location    String?
  isActive    Boolean   @default(true) @map("is_active")
  isChapelTotem Boolean @default(false) @map("is_chapel_totem")
  generatedBy Int?      @map("generated_by")
  generatedAt DateTime  @default(now()) @map("generated_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  scans        ScanLog[]
  reservations Reservation[]
  user         User?     @relation(fields: [generatedBy], references: [id])

  @@map("physical_qrs")
}

model ScanLog {
  id            Int      @id @default(autoincrement())
  physicalQrId  Int      @map("physical_qr_id")
  reservationId Int?     @map("reservation_id")
  scannedAt     DateTime @default(now()) @map("scanned_at")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(true)
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  physicalQR  PhysicalQR   @relation(fields: [physicalQrId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@map("scan_logs")
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  action        String
  entity        String
  entityId      Int?     @map("entity_id")
  userId        Int?     @map("user_id")
  targetUserId  Int?     @map("target_user_id")
  reservationId Int?     @map("reservation_id")
  meta          String?
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  user        User?        @relation("AuditActor", fields: [userId], references: [id])
  targetUser  User?        @relation("AuditTarget", fields: [targetUserId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// Configuración global del admin (singleton id=1)
model Settings {
  id                         Int      @id @default(1)
  freqOnceEnabled            Boolean  @default(true) @map("freq_once_enabled")
  freqDailyEnabled           Boolean  @default(true) @map("freq_daily_enabled")
  freqWeeklyEnabled          Boolean  @default(true) @map("freq_weekly_enabled")
  freqBiweeklyEnabled        Boolean  @default(true) @map("freq_biweekly_enabled")
  freqMonthlyEnabled         Boolean  @default(true) @map("freq_monthly_enabled")
  allowOffsetStartTimes      Boolean  @default(false) @map("allow_offset_start_times")
  allowThirtyMinuteDurations Boolean  @default(false) @map("allow_thirty_minute_durations")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// role: "captain" | "substitute"
// weekDays: "1,3" (Lun=1 … Dom=7); vacío = todos los días
// slotTimes: "07:00,10:00"; vacío = todas las horas
model RosterMember {
  id            Int      @id @default(autoincrement())
  role          String
  firstName     String   @map("first_name")
  lastName      String   @default("") @map("last_name")
  phone         String
  email         String?
  internalNotes String?  @map("internal_notes")
  weekDays      String?  @map("week_days")
  slotTimes     String?  @map("slot_times")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([role, isActive])
  @@map("roster_members")
}

// Franja de responsabilidad de un capitán (usuario con cuenta)
// dayOfWeek: 1=Lun … 7=Dom; null = todos los días
model CaptainRange {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  dayOfWeek   Int?     @map("day_of_week")
  startTime   String   @map("start_time") // "HH:MM"
  endTime     String   @map("end_time")   // "HH:MM"
  label       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdById Int?     @map("created_by_id")
  updatedById Int?     @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy     User?                 @relation("CaptainRangeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                 @relation("CaptainRangeUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  notifications CaptainNotification[]

  @@index([userId, isActive])
  @@map("captain_ranges")
}

// status: "pending" | "approved" | "rejected"
model SubstitutionRequest {
  id              Int       @id @default(autoincrement())
  reservationId   Int       @map("reservation_id")
  occurrenceDate  String    @map("occurrence_date")
  requestedByName String?   @map("requested_by_name")
  substituteName  String?   @map("substitute_name")
  substitutePhone String?   @map("substitute_phone")
  status          String    @default("pending")
  captainUserId   Int?      @map("captain_user_id")
  notes           String?
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  captainUser User?       @relation("SubstitutionReviews", fields: [captainUserId], references: [id], onDelete: SetNull)

  @@index([captainUserId, status])
  @@index([reservationId, occurrenceDate])
  @@map("substitution_requests")
}

// type: "open_slot" | "substitute_needed" | "gap_alert" | "urgent_open"
model CaptainNotification {
  id              Int      @id @default(autoincrement())
  captainUserId   Int      @map("captain_user_id")
  captainRangeId  Int?     @map("captain_range_id")
  type            String
  title           String
  message         String
  slotId          Int?     @map("slot_id")
  reservationId   Int?     @map("reservation_id")
  occurrenceDate  String?  @map("occurrence_date")
  isRead          Boolean  @default(false) @map("is_read")
  isUrgent        Boolean  @default(false) @map("is_urgent")
  createdAt       DateTime @default(now()) @map("created_at")

  captainUser  User          @relation("CaptainNotifications", fields: [captainUserId], references: [id], onDelete: Cascade)
  captainRange CaptainRange? @relation(fields: [captainRangeId], references: [id], onDelete: SetNull)

  @@index([captainUserId, isRead])
  @@map("captain_notifications")
}

model AttendanceLog {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  checkInAt  DateTime  @map("check_in_at")
  checkOutAt DateTime? @map("check_out_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, checkInAt])
  @@map("attendance_logs")
}

// direction: "inbound" | "outbound"
// messageType: "text" | "template" | "interactive" | "button" | "status" | "system"
model WhatsAppMessageLog {
  id          Int      @id @default(autoincrement())
  direction   String
  phone       String
  waMessageId String?  @unique @map("wa_message_id")
  messageType String   @default("text") @map("message_type")
  body        String
  meta        String?
  status      String?
  contactName String?  @map("contact_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phone, createdAt])
  @@index([direction, createdAt])
  @@index([createdAt])
  @@map("whatsapp_message_logs")
}

// Sesión conversacional del bot (flujo de reserva, FAQ)
model WhatsAppSession {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  step      String   @default("menu")
  data      String?
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whatsapp_sessions")
}
